package quanlyhinhtron;
import java.util.ArrayList;

public class testcircle {
    public static void main(String[] args) {
        System.out.println("*KIỂM TRA ĐA HÌNH VÀ TÍNH DIỆN TÍCH (getArea)*");
        ArrayList<circle> shapes = new ArrayList<>();
     
        shapes.add(new circle(1.5, "Blue"));
        shapes.add(new cylinder(1.0, "Green", 3.0));
        shapes.add(new circle(2.5, "Red"));

        int index = 1;
        for (circle shape : shapes) {
            System.out.println(index++ + ". " + shape.toString());  
            System.out.println("   --> Diện tích đáy (getArea()): " + String.format("%.2f", shape.getArea()) + "\n");
        }
    }
}