    private void addEvents() {
        tblPub.addMouseListener(new MouseAdapter() {
            public void mouseClicked(MouseEvent e) {
                int row = tblPub.getSelectedRow();
                if(row >= 0) { displayDetail(row); updateRecordStatus(); }
            }
        });

        btnPrev.addActionListener(e -> {
            int row = tblPub.getSelectedRow();
            if (row > 0) { tblPub.setRowSelectionInterval(row - 1, row - 1); displayDetail(row - 1); 
            updateRecordStatus(); }
        });

        btnNext.addActionListener(e -> {
            int row = tblPub.getSelectedRow();
            if (row < tblPub.getRowCount() - 1) { tblPub.setRowSelectionInterval(row + 1, row + 1); 
            displayDetail(row + 1); updateRecordStatus(); }
        });

        btnAdd.addActionListener(e -> { isEdit = false; setLock(false); clearText(); txtCode.requestFocus(); });
        btnEdit.addActionListener(e -> { if(!txtCode.getText().isEmpty()){ isEdit = true; 
        setLock(false); txtCode.setEnabled(false); 
        } 
        });

        btnSave.addActionListener(e -> {
            try {
                if (isEdit) pubDAL.update(txtCode.getText(), txtName.getText(), 
                		txtAddr.getText(), txtPhone.getText());
                else pubDAL.insert(txtCode.getText(), txtName.getText(), txtAddr.getText(), txtPhone.getText());
                loadData(); setLock(true); JOptionPane.showMessageDialog(this, "Thành công!");
            } catch (Exception ex) { JOptionPane.showMessageDialog(this, "Lỗi: " + ex.getMessage()); 
            }
        });

        btnDelete.addActionListener(e -> {
            String c = txtCode.getText();
            if(!c.isEmpty() && JOptionPane.showConfirmDialog(this, "Xóa NXB này?", "Cảnh báo", 0) == 0) {
                pubDAL.delete(c); loadData(); clearText();
            }
        });
        
        btnSearch.addActionListener(e -> new frmSearch().setVisible(true));
        btnExit.addActionListener(e -> System.exit(0));
    }

    private void updateRecordStatus() {
        int total = tblPub.getRowCount();
        int current = tblPub.getSelectedRow();
        lblStatus.setText(total == 0 ? "0 / 0" : (current + 1) + " / " + total);
    }

    private void loadData() {
        try {
            model.setRowCount(0);
            ResultSet rs = pubDAL.getAll();
            while(rs.next()) model.addRow(new Object[]{rs.getString(1), 
            		rs.getString(2), rs.getString(3), rs.getString(4)});
            updateRecordStatus();
        } catch (Exception e) { e.printStackTrace(); 
        }
    }

    private void displayDetail(int row) {
        txtCode.setText(tblPub.getValueAt(row, 0).toString());
        txtName.setText(tblPub.getValueAt(row, 1).toString());
        txtAddr.setText(tblPub.getValueAt(row, 2).toString());
        txtPhone.setText(tblPub.getValueAt(row, 3).toString());
    }

    private void setLock(boolean lock) {
        txtCode.setEnabled(!lock); txtName.setEnabled(!lock);
        txtAddr.setEnabled(!lock); txtPhone.setEnabled(!lock);
        btnSave.setEnabled(!lock); btnAdd.setEnabled(lock); 
        btnEdit.setEnabled(lock); btnDelete.setEnabled(lock);
    }

    private void clearText() { txtCode.setText(""); txtName.setText(""); 
    txtAddr.setText(""); txtPhone.setText(""); }

    public static void main(String[] args) { new frmPublisher().setVisible(true); 
    }
