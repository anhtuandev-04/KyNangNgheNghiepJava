package Interface;

import java.sql.*;
import Proccess.Library;
import javax.swing.*;
import javax.swing.table.DefaultTableModel;

public class frmSearch extends JFrame {
    private Library lib = new Library();
    private DefaultTableModel model = new DefaultTableModel(new String[]{"Mã Sách", "Tên Sách", "Mã NXB"}, 0);

    public frmSearch() {
        setTitle("Search Tool - Tìm kiếm sách theo NXB");
        setSize(600, 450);
        setLayout(null);
        setLocationRelativeTo(null);

        add(new JLabel("Nhập mã NXB cần tìm (ví dụ: p02 hoặc 23):")).setBounds(20, 20, 300, 25);
        JTextField txtSearch = new JTextField(); txtSearch.setBounds(20, 50, 300, 25); add(txtSearch);
        JButton btnFind = new JButton("Tìm kiếm"); btnFind.setBounds(330, 50, 100, 25); add(btnFind);

        JTable tbl = new JTable(model);
        JScrollPane sp = new JScrollPane(tbl);
        sp.setBounds(20, 100, 540, 250); add(sp);

        btnFind.addActionListener(e -> {
            try {
                model.setRowCount(0);
                ResultSet rs = lib.SearchBooksByPublisher(txtSearch.getText());
                while(rs != null && rs.next()) {
                    model.addRow(new String[]{rs.getString(1), rs.getString(2), rs.getString(3)});
                }
                if(model.getRowCount() == 0) JOptionPane.showMessageDialog(this, "Không có sách nào!");
            } catch (SQLException ex) { ex.printStackTrace(); }
        });
    }
}